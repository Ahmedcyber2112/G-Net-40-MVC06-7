@using GymManagementSystem.BLL.ViewModels.PlanViewModels
@model IEnumerable<PlanViewModel>

@{
    ViewData["Title"] = "Membership Plans";
}

@* رسائل النجاح والخطأ *@
@if (TempData["SuccessMessage"] != null)
{
    <div id="Alert" class="alert alert-success alert-dismissible fade show shadow-sm mt-3">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
else if (TempData["ErrorMessage"] != null)
{
    <div id="Alert" class="alert alert-danger alert-dismissible fade show shadow-sm mt-3">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container">
    <main role="main" class="pb-3">
        
        @* الهيدر + زرار الإضافة اللي كان ناقص *@
        <header class="d-flex justify-content-between mt-5 mb-4 align-items-center border-bottom pb-3">
            <div>
                <h2 class="text-primary-color mb-0"><i class="bi bi-tags-fill me-2"></i>Membership Plans</h2>
                <p class="text-muted mt-1 mb-0">Manage your gym membership packages</p>
            </div>
            <div>
                <a asp-action="Create" asp-controller="Plans" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i> Add New Plan
                </a>
            </div>
        </header>

        @if (Model != null && Model.Any())
        {
            <div class="row g-4">
                @foreach (var plan in Model)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card h-100 shadow-sm border-0 plan-card">
                            <div class="card-header text-white text-center py-4 @(plan.IsActive ? "bg-primary-color" : "bg-secondary")">
                                <h4 class="mb-0">@plan.Name</h4>
                            </div>
                            
                            <div class="card-body d-flex flex-column">
                                <div class="text-center mb-4">
                                    <div class="display-4 fw-bold text-primary-color">@plan.Price.ToString("N0")</div>
                                    <small class="text-muted">EGP</small>
                                </div>

                                <div class="mb-3">
                                    <p class="text-muted mb-2">
                                        <i class="bi bi-calendar-check text-primary-color me-2"></i>
                                        <strong>Duration:</strong> @plan.DurationInDays Days
                                    </p>
                                    <p class="text-muted mb-1">
                                        <i class="bi bi-file-text text-primary-color me-2"></i>
                                        <strong>Description:</strong>
                                    </p>
                                    <p class="small text-muted ps-4">@plan.Description</p>
                                </div>

                                <div class="mt-auto">
                                    <div class="d-grid gap-2">
                                        <a asp-action="Details" asp-controller="Plans" asp-route-id="@plan.Id" class="btn btn-outline-secondary btn-sm">
                                            <i class="bi bi-eye me-1"></i>View Details
                                        </a>

                                        <div class="d-flex gap-2">
                                            <a asp-action="Edit" asp-controller="Plans" asp-route-id="@plan.Id" class="btn btn-outline-primary btn-sm flex-fill">
                                                <i class="bi bi-pencil me-1"></i>Edit
                                            </a>
                                            
                                            <form asp-action="Activate" asp-controller="Plans" asp-route-id="@plan.Id" method="post" class="flex-fill">
                                                <button type="submit" class="btn btn-outline-dark btn-sm w-100 @(plan.IsActive ? "text-danger" : "text-success")">
                                                    @if (plan.IsActive)
                                                    {
                                                        <i class="bi bi-x-circle me-1"></i> <span>Deactivate</span>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-check-circle me-1"></i> <span>Activate</span>
                                                    }
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5 bg-light rounded-3 mt-4 border">
                <i class="bi bi-inbox display-1 text-muted"></i>
                <h4 class="mt-3 text-muted">No Plans Available</h4>
                <p class="text-muted mb-4">You haven't added any membership plans yet.</p>
                <a asp-action="Create" asp-controller="Plans" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i> Create Your First Plan
                </a>
            </div>
        }
    </main>
</div>

@section Scripts {
    <partial name="_AlertBoxScript" />
}